{
  "name": "daily-tech",
  "version": "0.9.2",
  "private": true,
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "cap:sync": "npx cap sync",
    "cap:android": "npm run build && npx cap sync && npx cap open android",
    "cap:run": "npx cap run android",
    "build:apk": "npm run build && npx cap sync && cd android && ./gradlew assembleRelease",
    "build:apk:win": "npm run build && npx cap sync && cd android && gradlew.bat assembleRelease"
  },
  "devDependencies": {
    "@sveltejs/adapter-static": "^3.0.0",
    "@sveltejs/kit": "^2.0.0",
    "@sveltejs/vite-plugin-svelte": "^3.0.0",
    "autoprefixer": "^10.4.16",
    "postcss": "^8.4.32",
    "svelte": "^4.2.8",
    "svelte-check": "^3.6.0",
    "tailwindcss": "^3.4.0",
    "tslib": "^2.6.2",
    "typescript": "^5.0.0",
    "vite": "^5.0.0"
  },
  "dependencies": {
    "@capacitor-community/http": "^1.4.1",
    "@capacitor/android": "^5.0.0",
    "@capacitor/app": "^5.0.8",
    "@capacitor/cli": "^5.0.0",
    "@capacitor/core": "^5.0.0",
    "@capacitor/preferences": "^5.0.0",
    "bits-ui": "^0.21.0",
